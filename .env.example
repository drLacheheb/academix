# --- API Server Configurations ---
API_SECRET_KEY=your-api-secret-key-here
DATABASE_URL=sqlite:///jobs.db
STALE_CLAIM_TIMEOUT_MINUTES=10
PYTHONIOENCODING=utf-8
MODELS_DIR=models
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# --- Crawling & Sourcing Configurations ---
API_URL=http://localhost:8000
API_TOKEN=your-api-secret-key-here
MAX_PAGES=5
CRAWL_ONCE=false
CRAWL_INTERVAL=3600

# --- General Agent Configurations ---
AGENT_POLL_INTERVAL=10

# --- Refinement Configurations ---
MODEL_PATH=unsloth/gemma-4-E2B-it-GGUF/gemma-4-E2B-it-Q4_K_M.gguf
MAX_LENGTH=4096
TEMPERATURE=0.0
MAX_TEXT_CHARS=3000
AGENT_NAME=refinement-worker

# --- Translation Configurations ---
NLLB_MODEL_PATH=mijuanlo/nllb-200-distilled-600M-ct2-int8

# --- Logging Configurations ---
LOG_FILE=agent.log

